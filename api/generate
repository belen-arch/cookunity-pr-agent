export const config = { runtime: 'edge' };

const ANTHROPIC_API_KEY = process.env.ANTHROPIC_API_KEY;
const NOTION_API_KEY = process.env.NOTION_API_KEY;
const NOTION_PARENT_PAGE_ID = '3276c6b786ba80589c80efe9454c5470';
const NOTION_DB_ID = '26b08a0c-6811-4536-8391-594c571035b3';

export default async function handler(req) {
  if (req.method === 'OPTIONS') {
    return new Response(null, { headers: { 'Access-Control-Allow-Origin': '*', 'Access-Control-Allow-Methods': 'POST', 'Access-Control-Allow-Headers': 'Content-Type' } });
  }
  if (req.method !== 'POST') return new Response('Method not allowed', { status: 405 });

  const body = await req.json();
  const { submitterName, email, campaignName, type, keyMessage, proofPoints, culturalRelevance, spokesperson, audience, markets, priority, launchDate, assets, context } = body;

  const brief = `CAMPAIGN BRIEF — COOKUNITY PR DASHBOARD
Submitted by: ${submitterName}${email ? ' (' + email + ')' : ''}
Campaign Name: ${campaignName}
Announcement Type: ${type || 'Not specified'}
Key Message: ${keyMessage}
Supporting Proof Points: ${proofPoints || 'None provided'}
Cultural Relevance / Why Now: ${culturalRelevance || 'Not specified'}
Spokesperson: ${spokesperson || 'Not specified'}
Target Audience: ${audience || 'Not specified'}
Market Scope: ${markets || 'National'}
PR Priority: ${priority || 'Not specified'}
Target Launch / Embargo Date: ${launchDate || 'Not specified'}
Available Assets: ${assets || 'Not specified'}
Additional Context: ${context || 'None'}`;

  const system = `You are a senior PR strategist for CookUnity — America's first chef-to-you meal delivery platform. CookUnity features 180+ award-winning chefs (Marcus Samuelsson, Cat Cora, Rick Bayless, Einat Admony, Aarthi Sampath, Akhtar Nawab, Gaurav Raj, Meena Sreenivas, Jose Garces, Patrick Kriss), 300+ weekly dishes, 50M+ meals served, $605M revenue in 2025 (up from $111M in 2022), $250M from General Catalyst (Nov 2025), 8 kitchens across US and Canada, average chef earns $850K/year. Key past campaigns: Diwali Indian food trends, General Catalyst funding, NYGC TGL golf sponsorship, flavrs acquisition, Miami FC partnership, SuperBowl chef tips, Chef Aarthi new restaurant NYC.

Produce a complete PR Strategy Memo. Think like a senior strategist — direct, specific, named. No vague advice.

Use these EXACT section headers with ###:
### PR Opportunity Summary
### Why This Matters Now
### Recommended Strategy
### Best Media Angles
### Target Outlets & Journalists
### Spokesperson Recommendation
### Timing & Embargo
### Risks & Weaknesses
### Missing Ingredients
### Suggested Next Steps
### Draft Pitch Directions

CRITICAL: In "Target Outlets & Journalists" — name SPECIFIC publications AND specific journalist names or beats. In "Draft Pitch Directions" — 2-3 outlines with subject line + 2-3 sentence hook each. Flag missing info explicitly. Never invent data not in the brief.`;

  // Step 1: Generate strategy with Claude
  const claudeRes = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'x-api-key': ANTHROPIC_API_KEY,
      'anthropic-version': '2023-06-01'
    },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 4000,
      system,
      messages: [{ role: 'user', content: brief }]
    })
  });

  const claudeData = await claudeRes.json();
  if (claudeData.error) throw new Error(claudeData.error.message);
  const strategy = claudeData.content.map(c => c.text || '').join('');

  // Step 2: Create Notion strategy page
  const notionPageRes = await fetch('https://api.notion.com/v1/pages', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${NOTION_API_KEY}`,
      'Content-Type': 'application/json',
      'Notion-Version': '2022-06-28'
    },
    body: JSON.stringify({
      parent: { page_id: NOTION_PARENT_PAGE_ID },
      icon: { type: 'emoji', emoji: '📋' },
      properties: {
        title: { title: [{ text: { content: `${campaignName} — PR Strategy Memo` } }] }
      },
      children: buildNotionBlocks(submitterName, email, campaignName, type, priority, markets, spokesperson, audience, launchDate, assets, keyMessage, proofPoints, culturalRelevance, context, strategy)
    })
  });

  const notionPage = await notionPageRes.json();
  const notionPageUrl = notionPage.url || '';

  // Step 3: Add to submissions database
  await fetch('https://api.notion.com/v1/pages', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${NOTION_API_KEY}`,
      'Content-Type': 'application/json',
      'Notion-Version': '2022-06-28'
    },
    body: JSON.stringify({
      parent: { database_id: NOTION_DB_ID },
      properties: {
        'Campaign Name': { title: [{ text: { content: campaignName } }] },
        'Submitted By': { rich_text: [{ text: { content: submitterName } }] },
        'Email': { email: email || null },
        'Announcement Type': type ? { select: { name: type } } : undefined,
        'PR Priority': priority ? { select: { name: priority } } : undefined,
        'Market Scope': { rich_text: [{ text: { content: markets || 'National' } }] },
        'Spokesperson': { rich_text: [{ text: { content: spokesperson || '' } }] },
        'Key Message': { rich_text: [{ text: { content: keyMessage.slice(0, 2000) } }] },
        'Strategy Page': { url: notionPageUrl || null },
        ...(launchDate ? { 'Launch Date': { date: { start: launchDate } } } : {})
      }
    })
  });

  return new Response(JSON.stringify({ strategy, notionPageUrl }), {
    headers: { 'Content-Type': 'application/json', 'Access-Control-Allow-Origin': '*' }
  });
}

function buildNotionBlocks(submitterName, email, campaignName, type, priority, markets, spokesperson, audience, launchDate, assets, keyMessage, proofPoints, culturalRelevance, context, strategy) {
  const blocks = [
    { object: 'block', type: 'callout', callout: { rich_text: [{ text: { content: `Auto-generated by PR Strategy Agent · Submitted by ${submitterName}${email ? ' (' + email + ')' : ''} · ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}` } }], icon: { type: 'emoji', emoji: '✅' }, color: 'green_background' } },
    { object: 'block', type: 'heading_2', heading_2: { rich_text: [{ text: { content: 'Campaign Brief' } }] } },
    tableRow('Campaign Name', campaignName),
    tableRow('Submitted By', submitterName + (email ? ` (${email})` : '')),
    tableRow('Announcement Type', type || 'Not specified'),
    tableRow('PR Priority', priority || 'Not specified'),
    tableRow('Market Scope', markets || 'National'),
    tableRow('Spokesperson', spokesperson || 'Not specified'),
    tableRow('Target Audience', audience || 'Not specified'),
    tableRow('Launch Date', launchDate || 'Not specified'),
    tableRow('Assets', assets || 'Not specified'),
    tableRow('Key Message', keyMessage),
    proofPoints && tableRow('Proof Points', proofPoints),
    culturalRelevance && tableRow('Cultural Relevance', culturalRelevance),
    context && tableRow('Additional Context', context),
    { object: 'block', type: 'divider', divider: {} },
    { object: 'block', type: 'heading_2', heading_2: { rich_text: [{ text: { content: 'PR Strategy Memo' } }] } },
    ...parseStrategyToBlocks(strategy)
  ].filter(Boolean);
  return blocks;
}

function tableRow(label, value) {
  if (!value) return null;
  return {
    object: 'block', type: 'paragraph',
    paragraph: { rich_text: [
      { text: { content: label + ': ' }, annotations: { bold: true } },
      { text: { content: value.slice(0, 2000) } }
    ]}
  };
}

function parseStrategyToBlocks(text) {
  const blocks = [];
  const lines = text.split('\n');
  let listItems = [];

  const flushList = () => {
    if (listItems.length > 0) {
      listItems.forEach(item => {
        blocks.push({ object: 'block', type: 'bulleted_list_item', bulleted_list_item: { rich_text: [{ text: { content: item.slice(0, 2000) } }] } });
      });
      listItems = [];
    }
  };

  for (const line of lines) {
    if (line.startsWith('### ')) {
      flushList();
      blocks.push({ object: 'block', type: 'heading_3', heading_3: { rich_text: [{ text: { content: line.slice(4) } }] } });
    } else if (/^[-*] /.test(line)) {
      listItems.push(line.slice(2).replace(/\*\*(.+?)\*\*/g, '$1'));
    } else if (/^\d+\. /.test(line)) {
      listItems.push(line.replace(/^\d+\. /, '').replace(/\*\*(.+?)\*\*/g, '$1'));
    } else if (line.trim()) {
      flushList();
      blocks.push({ object: 'block', type: 'paragraph', paragraph: { rich_text: [{ text: { content: line.replace(/\*\*(.+?)\*\*/g, '$1').slice(0, 2000) } }] } });
    }
  }
  flushList();
  return blocks;
}
