const ANTHROPIC_API_KEY = process.env.ANTHROPIC_API_KEY;
const NOTION_API_KEY = process.env.NOTION_API_KEY;
const NOTION_PARENT_PAGE_ID = '3276c6b786ba80589c80efe9454c5470';
const NOTION_DB_ID = '26b08a0c-6811-4536-8391-594c571035b3';

module.exports = async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  try {
    const { submitterName, email, campaignName, type, keyMessage, proofPoints, culturalRelevance, spokesperson, audience, markets, priority, launchDate, assets, context } = req.body;
    if (!campaignName || !keyMessage) return res.status(400).json({ error: 'Campaign name and key message are required.' });

    const brief = `CAMPAIGN BRIEF — COOKUNITY PR DASHBOARD
Submitted by: ${submitterName}${email ? ' (' + email + ')' : ''}
Campaign Name: ${campaignName}
Announcement Type: ${type || 'Not specified'}
Key Message: ${keyMessage}
Supporting Proof Points: ${proofPoints || 'None provided'}
Cultural Relevance / Why Now: ${culturalRelevance || 'Not specified'}
Spokesperson: ${spokesperson || 'Not specified'}
Target Audience: ${audience || 'Not specified'}
Market Scope: ${markets || 'National'}
PR Priority: ${priority || 'Not specified'}
Target Launch / Embargo Date: ${launchDate || 'Not specified'}
Available Assets: ${assets || 'Not specified'}
Additional Context: ${context || 'None'}`;

    const system = `You are a senior PR strategist for CookUnity — America's first chef-to-you meal delivery platform. CookUnity features 180+ award-winning chefs (Marcus Samuelsson, Cat Cora, Rick Bayless, Einat Admony, Aarthi Sampath, Akhtar Nawab, Gaurav Raj, Meena Sreenivas, Jose Garces, Patrick Kriss), 300+ weekly dishes, 50M+ meals served, $605M revenue in 2025 (up from $111M in 2022), $250M from General Catalyst (Nov 2025), 8 kitchens across US and Canada, average chef earns $850K/year. Key past campaigns: Diwali Indian food trends, General Catalyst funding, NYGC TGL golf sponsorship, flavrs acquisition, Miami FC partnership, SuperBowl chef tips.

Produce a complete PR Strategy Memo. Think like a senior strategist — direct, specific, named. No vague advice.

Use these EXACT section headers with ###:
### PR Opportunity Summary
### Why This Matters Now
### Recommended Strategy
### Best Media Angles
### Target Outlets & Journalists
### Spokesperson Recommendation
### Timing & Embargo
### Risks & Weaknesses
### Missing Ingredients
### Suggested Next Steps
### Draft Pitch Directions

In "Target Outlets & Journalists": name SPECIFIC publications AND specific journalist names or beats. In "Draft Pitch Directions": 2-3 outlines with subject line + 2-3 sentence hook each. Flag missing info explicitly.`;

    const claudeRes = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-api-key': ANTHROPIC_API_KEY, 'anthropic-version': '2023-06-01' },
      body: JSON.stringify({ model: 'claude-sonnet-4-20250514', max_tokens: 4000, system, messages: [{ role: 'user', content: brief }] })
    });
    const claudeData = await claudeRes.json();
    if (claudeData.error) return res.status(500).json({ error: `Claude error: ${claudeData.error.message}` });
    const strategy = claudeData.content.map(c => c.text || '').join('');

    const notionPageRes = await fetch('https://api.notion.com/v1/pages', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${NOTION_API_KEY}`, 'Content-Type': 'application/json', 'Notion-Version': '2022-06-28' },
      body: JSON.stringify({
        parent: { page_id: NOTION_PARENT_PAGE_ID },
        icon: { type: 'emoji', emoji: '📋' },
        properties: { title: { title: [{ text: { content: `${campaignName} — PR Strategy Memo` } }] } },
        children: buildBlocks(submitterName, email, campaignName, type, priority, markets, spokesperson, audience, launchDate, assets, keyMessage, proofPoints, culturalRelevance, context, strategy)
      })
    });
    const notionPage = await notionPageRes.json();
    if (notionPage.object === 'error') return res.status(500).json({ error: `Notion error: ${notionPage.message}` });
    const notionPageUrl = notionPage.url || '';

    await fetch('https://api.notion.com/v1/pages', {
      method: 'POST',
      headers: { 'Authorization': `Bearer ${NOTION_API_KEY}`, 'Content-Type': 'application/json', 'Notion-Version': '2022-06-28' },
      body: JSON.stringify({
        parent: { database_id: NOTION_DB_ID },
        properties: {
          'Campaign Name': { title: [{ text: { content: campaignName } }] },
          'Submitted By': { rich_text: [{ text: { content: submitterName || '' } }] },
          'Email': { email: email || null },
          'Announcement Type': type ? { select: { name: mapType(type) } } : undefined,
          'PR Priority': priority ? { select: { name: priority } } : undefined,
          'Market Scope': { rich_text: [{ text: { content: markets || 'National' } }] },
          'Spokesperson': { rich_text: [{ text: { content: spokesperson || '' } }] },
          'Key Message': { rich_text: [{ text: { content: keyMessage.slice(0, 2000) } }] },
          'Strategy Page': { url: notionPageUrl || null },
          ...(launchDate ? { 'Launch Date': { date: { start: launchDate } } } : {})
        }
      })
    });

    return res.status(200).json({ strategy, notionPageUrl });
  } catch (e) {
    console.error(e);
    return res.status(500).json({ error: e.message });
  }
};

function mapType(t) {
  const valid = ['Food trend / data story','Chef launch / partnership','Brand campaign','Funding / business milestone','Sports / lifestyle partnership','Cultural moment','Corporate news','Seasonal campaign','Reactive pitch'];
  return valid.includes(t) ? t : 'Brand campaign';
}

function buildBlocks(submitterName, email, campaignName, type, priority, markets, spokesperson, audience, launchDate, assets, keyMessage, proofPoints, culturalRelevance, context, strategy) {
  const date = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  return [
    { object:'block', type:'callout', callout:{ rich_text:[{text:{content:`Auto-generated by PR Strategy Agent · Submitted by ${submitterName}${email?' ('+email+')':''} · ${date}`}}], icon:{type:'emoji',emoji:'✅'}, color:'green_background' }},
    { object:'block', type:'heading_2', heading_2:{ rich_text:[{text:{content:'Campaign Brief'}}] }},
    row('Campaign', campaignName), row('Submitted By', submitterName+(email?` (${email})`:'') ),
    row('Type', type), row('Priority', priority), row('Markets', markets),
    row('Spokesperson', spokesperson), row('Audience', audience),
    row('Launch Date', launchDate), row('Assets', assets), row('Key Message', keyMessage),
    proofPoints ? row('Proof Points', proofPoints) : null,
    culturalRelevance ? row('Why Now', culturalRelevance) : null,
    context ? row('Context', context) : null,
    { object:'block', type:'divider', divider:{} },
    { object:'block', type:'heading_2', heading_2:{ rich_text:[{text:{content:'PR Strategy Memo'}}] }},
    ...parseBlocks(strategy)
  ].filter(Boolean);
}

function row(label, value) {
  if (!value) return null;
  return { object:'block', type:'paragraph', paragraph:{ rich_text:[{text:{content:label+': '},annotations:{bold:true}},{text:{content:value.slice(0,2000)}}] }};
}

function parseBlocks(text) {
  const blocks = []; const lines = text.split('\n'); let list = [];
  const flush = () => { list.forEach(i => blocks.push({object:'block',type:'bulleted_list_item',bulleted_list_item:{rich_text:[{text:{content:i.slice(0,2000)}}]}})); list=[]; };
  for (const line of lines) {
    if (line.startsWith('### ')) { flush(); blocks.push({object:'block',type:'heading_3',heading_3:{rich_text:[{text:{content:line.slice(4)}}]}}); }
    else if (/^[-*] /.test(line)) list.push(line.slice(2).replace(/\*\*(.+?)\*\*/g,'$1'));
    else if (/^\d+\. /.test(line)) list.push(line.replace(/^\d+\. /,'').replace(/\*\*(.+?)\*\*/g,'$1'));
    else if (line.trim()) { flush(); blocks.push({object:'block',type:'paragraph',paragraph:{rich_text:[{text:{content:line.replace(/\*\*(.+?)\*\*/g,'$1').slice(0,2000)}}]}}); }
  }
  flush(); return blocks;
}
